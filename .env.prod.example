# Production config for docker-compose.prod.yml.
# Copy to .env, fill in real values, and keep it out of version control.
# No insecure defaults here on purpose — the compose file requires every
# one of these to be set explicitly.

# --- Deployment topology: pick ONE of the two setups below. ---
#
# (A) Same-origin via nginx (this repo's default — apps/web/nginx.conf
#     proxies /api, /admin, /static, /collab under the one public domain).
#     DJANGO_ALLOWED_HOSTS, FRONTEND_URL, CORS_ALLOWED_ORIGINS and
#     CSRF_TRUSTED_ORIGINS are all the SAME host:
#
#   DJANGO_ALLOWED_HOSTS=freeleaf.example.com
#   FRONTEND_URL=https://freeleaf.example.com
#   CORS_ALLOWED_ORIGINS=https://freeleaf.example.com
#   CSRF_TRUSTED_ORIGINS=https://freeleaf.example.com
#   ORCID_REDIRECT_URI=https://freeleaf.example.com/api/auth/orcid/callback
#   VITE_API_ORIGIN=                                  # empty: web's own JS calls itself, same origin
#
# (B) Split subdomains — your own reverse proxy routes the web app and the
#     api to two DIFFERENT hostnames (e.g. freeleaf.example.com for the SPA,
#     api.freeleaf.example.com straight to the api container/service — a
#     sub-subdomain works the same way a sibling one like freeleaf-api.
#     example.com would), bypassing apps/web/nginx.conf's same-origin
#     proxying entirely. Browser JS calls from the SPA to the api are now
#     genuinely cross-origin, so these are no longer all the same value:
#
#   DJANGO_ALLOWED_HOSTS=api.freeleaf.example.com   # the host Django itself sees
#   FRONTEND_URL=https://freeleaf.example.com        # the SPA's host (email links, post-OAuth redirect target)
#   CORS_ALLOWED_ORIGINS=https://freeleaf.example.com   # the SPA's origin, so its fetch() calls are allowed
#   CSRF_TRUSTED_ORIGINS=https://freeleaf.example.com   # same reasoning
#   CSRF_COOKIE_DOMAIN=.freeleaf.example.com         # the shared parent domain — see below
#   ORCID_REDIRECT_URI=https://api.freeleaf.example.com/api/auth/orcid/callback  # the api's own host
#   VITE_API_ORIGIN=https://api.freeleaf.example.com  # baked into the JS bundle at BUILD time — see below
#
#   Getting DJANGO_ALLOWED_HOSTS wrong here fails as a 400 "DisallowedHost"
#   in the api logs (`docker compose -f docker-compose.prod.yml logs api`),
#   not as anything visible in the browser beyond a generic error — check
#   the logs first if auth is failing after a split-subdomain deploy.
#
#   CSRF_COOKIE_DOMAIN matters once login itself works: without it, the
#   csrftoken cookie is host-only (scoped to just the api's own host), so
#   the SPA's JS can set/receive it but can never *read* it via
#   document.cookie to echo back as the X-CSRFToken header on POST/PATCH/
#   DELETE requests — every write fails with "Forbidden (CSRF token
#   missing.)" even though sign-in itself succeeded (the session cookie
#   doesn't have this problem — subdomains are same-site, so the browser
#   resends it automatically regardless; only the CSRF double-submit
#   pattern needs JS to actually read the cookie value). Set it to the
#   parent domain shared by both hosts, with a leading dot.
#
#   VITE_API_ORIGIN is read by `web`'s Dockerfile.prod as a build ARG, not
#   an environment variable the running container reads — Vite bakes it
#   into the static JS at build time. Changing it after the fact needs a
#   rebuild, not just a restart: `docker compose -f docker-compose.prod.yml
#   up -d --build web` (a plain `up -d` reuses the old image unchanged).
#
# Values below assume (A); edit to (B)'s shape if that's your setup.

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=freeleaf.example.com
FRONTEND_URL=https://freeleaf.example.com
CORS_ALLOWED_ORIGINS=https://freeleaf.example.com
CSRF_TRUSTED_ORIGINS=https://freeleaf.example.com
CSRF_COOKIE_DOMAIN=
VITE_API_ORIGIN=

# --- Postgres ---
POSTGRES_DB=freeleaf
POSTGRES_USER=freeleaf
POSTGRES_PASSWORD=

# --- MinIO (object storage) ---
MINIO_ROOT_USER=freeleaf
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=freeleaf

# --- Email (Mailgun via django-anymail) ---
DEFAULT_FROM_EMAIL=noreply@freeleaf.example.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.freeleaf.example.com

# --- ORCID OAuth2 — register a production app at https://orcid.org ---
ORCID_ENV=production
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://freeleaf.example.com/api/auth/orcid/callback
