# Production config for docker-compose.prod.yml.
# Copy to .env, fill in real values, and keep it out of version control.
# No insecure defaults here on purpose — the compose file requires every
# one of these to be set explicitly.

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=freeleaf.example.com

# --- Public URL ---
# The single domain this whole stack is served from (nginx proxies /api,
# /admin, /static, /collab under it — see apps/web/nginx.conf). Same value
# for all three: same-origin means CORS/CSRF are same-site by construction.
FRONTEND_URL=https://freeleaf.example.com
CORS_ALLOWED_ORIGINS=https://freeleaf.example.com
CSRF_TRUSTED_ORIGINS=https://freeleaf.example.com

# --- Postgres ---
POSTGRES_DB=freeleaf
POSTGRES_USER=freeleaf
POSTGRES_PASSWORD=

# --- MinIO (object storage) ---
MINIO_ROOT_USER=freeleaf
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=freeleaf

# --- Email (Mailgun via django-anymail) ---
DEFAULT_FROM_EMAIL=noreply@freeleaf.example.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.freeleaf.example.com

# --- ORCID OAuth2 — register a production app at https://orcid.org ---
ORCID_ENV=production
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://freeleaf.example.com/api/auth/orcid/callback
