DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_DB=freeleaf
POSTGRES_USER=freeleaf
POSTGRES_PASSWORD=freeleaf
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Auth (Plan.md §9 Phase 1)
# Access the web app via http://localhost:5173 consistently — 127.0.0.1 is
# allowed here too (CORS) but is a different *site* to the browser, so
# cookies won't carry over if you mix the two hostnames across a session.
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Magic-link email — Mailpit in dev (docker-compose.yml)
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=noreply@freeleaf.local

# ORCID OAuth2 sandbox app — register at https://sandbox.orcid.org
ORCID_ENV=sandbox
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:8000/api/auth/orcid/callback

# Object storage (Plan.md §4/§9 Phase 2) — MinIO in dev (docker-compose.yml)
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=freeleaf
MINIO_ROOT_PASSWORD=freeleafsecret
MINIO_BUCKET=freeleaf
